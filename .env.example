LARK_APP_ID=cli_xxxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxx
LARK_VERIFICATION_TOKEN=

# Optional — operator dashboard notifications.
# When OPERATOR_DAILY_DIGEST_CHAT_ID is set, scheduler_daemon will:
#   - push a daily Project Echo status digest at OPERATOR_DAILY_DIGEST_HOUR_TAIPEI (default 09:00 Asia/Taipei)
#   - ping you whenever a pending review's age crosses OPERATOR_AGING_REVIEW_HOURS (default 4h)
# Leave empty to disable both. The chat_id is the one Lark stores per
# DM/group — easiest source: any prior `lark_message_received` audit
# event has it on the payload.
OPERATOR_DAILY_DIGEST_CHAT_ID=
OPERATOR_DAILY_DIGEST_HOUR_TAIPEI=9
OPERATOR_AGING_REVIEW_HOURS=4
OPERATOR_CUSTOMER_ID=customer_a
